def get_customer_history_enhanced(customer_id):
    customer_apps = df_applications[df_applications['Клиент'] == customer_id]
    total_apps = len(customer_apps)
    successful_apps = customer_apps['target'].sum() if 'target' in customer_apps.columns else 0
    conversion_rate = successful_apps / total_apps if total_apps > 0 else 0

    customer = df_customers[df_customers['customer_id'] == customer_id]
    if len(customer) > 0:
        c = customer.iloc[0]
        return {
            'total_applications': total_apps,
            'successful_applications': successful_apps,
            'conversion_rate': conversion_rate,
            'avg_contract_amount': c.get('avg_contract_amount', 0),
            'contract_count': c.get('contract_count', 0),
            'contract_signed_rate': c.get('contract_signed_rate', 0),
            'avg_order_quantity': c.get('avg_order_quantity', 0),
            'customer_avg_purchase_cost': c.get('customer_avg_purchase_cost', 0),
            'avg_contract_payment_sum': c.get('avg_contract_payment_sum', 0)
        }
    else:
        return {
            'total_applications': total_apps,
            'successful_applications': successful_apps,
            'conversion_rate': conversion_rate,
            'avg_contract_amount': 0,
            'contract_count': 0,
            'contract_signed_rate': 0,
            'avg_order_quantity': 0,
            'customer_avg_purchase_cost': 0,
            'avg_contract_payment_sum': 0
        }

def get_manager_history_enhanced(manager_id):
    manager_apps = df_applications[df_applications['Менеджер'] == manager_id]
    total_handled = len(manager_apps)
    successful_handled = manager_apps['target'].sum() if 'target' in manager_apps.columns else 0
    conversion_rate = successful_handled / total_handled if total_handled > 0 else 0

    manager_contracts = customer_contracts[customer_contracts['document_manager'] == manager_id] if len(customer_contracts) > 0 else pd.DataFrame()
    avg_contract_amount = manager_contracts['document_amount'].mean() if len(manager_contracts) > 0 else 0
    contracts_count = len(manager_contracts)

    return {
        'total_handled': total_handled,
        'manager_conversion_rate': conversion_rate,
        'manager_avg_contract_amount': avg_contract_amount,
        'manager_contracts_count': contracts_count
    }

