acc = accuracy_score(y_test, y_pred)
prec = precision_score(y_test, y_pred)
rec = recall_score(y_test, y_pred)
f1 = f1_score(y_test, y_pred)

print(f"\n  AUC-ROC: {auc:.4f}  {'✅ Отлично' if auc > 0.75 else '✅ Хорошо' if auc > 0.7 else '⚠️ Средне'}")
print(f"  Accuracy: {acc:.4f}  (доля верных ответов)")
