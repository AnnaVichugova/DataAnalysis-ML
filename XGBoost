def extract_urgency(text):
    if pd.isna(text):
        return 0
    text = str(text).lower()
    urgency_words = ['срочно', 'срочная', 'срочный', 'горящая', 'немедленно', 'сегодня', 'завтра']
    return 1 if any(word in text for word in urgency_words) else 0

def extract_politeness(text):
    if pd.isna(text):
        return 0
    text = str(text).lower()
    polite_words = ['здравствуйте', 'пожалуйста', 'спасибо', 'благодарю', 'добрый день', 'извините']
    return sum(1 for word in polite_words if word in text)

def extract_quantity(text):
    if pd.isna(text):
        return 1
    import re
    text = str(text)
    numbers = re.findall(r'\d+', text)
    return int(numbers[0]) if numbers else 1

# ---- ФУНКЦИИ ДЛЯ РАСЧЕТА ИСТОРИИ И РЕГИОНА ----
def get_customer_history(customer_id):
    customer_apps = df_applications[df_applications['Клиент'] == customer_id]
    total_apps = len(customer_apps)
    successful_apps = len(customer_apps[customer_apps['Статус'] == 'завершена'])
    conversion_rate = successful_apps / total_apps if total_apps > 0 else 0
    return {'total_applications': total_apps, 'successful_applications': successful_apps, 'conversion_rate': conversion_rate}

def get_manager_history(manager_id):
    manager_apps = df_applications[df_applications['Менеджер'] == manager_id]
    total_handled = len(manager_apps)
    successful_handled = len(manager_apps[manager_apps['Статус'] == 'завершена'])
    conversion_rate = successful_handled / total_handled if total_handled > 0 else 0
    return {'total_handled': total_handled, 'manager_conversion_rate': conversion_rate}

def extract_region(address):
    if pd.isna(address):
        return 'не указан'
    address = str(address)
    if 'москв' in address.lower() or 'moscow' in address.lower():
        return 'Москва'
    elif 'спб' in address.lower() or 'санкт' in address.lower() or 'петербург' in address.lower():
        return 'Санкт-Петербург'
    else:
        return 'Регионы'

