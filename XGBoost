def predict_application(customer_id, manager_id, source, content, date=None, verbose=False):
    """Функция для предсказания конверсии по заданным параметрам"""

    if date is None:
        date = datetime.now().strftime('%Y-%m-%d')

    # Получаем данные клиента
    customer_data = df_customers[df_customers['customer_id'] == customer_id]
    if len(customer_data) > 0:
        customer_info = customer_data.iloc[0]
    else:
        customer_info = None

    # Получаем данные менеджера
    manager_data = df_managers[df_managers['manager_id'] == manager_id]
    if len(manager_data) > 0:
        manager_info = manager_data.iloc[0]
    else:
        manager_info = None

    # Расчет исторических признаков
    customer_hist = get_customer_history_enhanced(customer_id)
    manager_hist = get_manager_history_enhanced(manager_id)

    if verbose:
        print(f"\n📊 ИСТОРИЯ КЛИЕНТА:")
        print(f"      Заявок: {customer_hist['total_applications']}")
        print(f"      Успешных заявок: {customer_hist['successful_applications']}")
        print(f"      Конверсия: {customer_hist['conversion_rate']:.1%}")
        print(f"      Договоров: {customer_hist['contract_count']}")
        print(f"      Средняя сумма: {customer_hist['avg_contract_amount']:,.0f} руб.")

    # Формируем признаки
    date_obj = pd.to_datetime(date, errors='coerce')
    if pd.isna(date_obj):
        date_obj = pd.Timestamp.now()

    features = {
        'Источник': source,
        'customer_type': customer_info['customer_type'] if customer_info is not None else 'unknown',
        'customer_status': customer_info['customer_status'] if customer_info is not None else 'unknown',
        'manager_specialization': manager_info['manager_specialization'] if manager_info is not None else 'unknown',
        'equipment_category': extract_equipment_type(content),
        'urgency': extract_urgency(content),
        'politeness_score': extract_politeness(content),
        'request_quantity': extract_quantity(content),
        'total_applications': customer_hist['total_applications'],
        'successful_applications': customer_hist['successful_applications'],
        'conversion_rate': customer_hist['conversion_rate'],
        'avg_contract_amount': customer_hist['avg_contract_amount'],
        'contract_count': customer_hist['contract_count'],
        'contract_signed_rate': customer_hist['contract_signed_rate'],
        'avg_order_quantity': customer_hist['avg_order_quantity'],
        'customer_avg_purchase_cost': customer_hist['customer_avg_purchase_cost'],
        'avg_contract_payment_sum': customer_hist['avg_contract_payment_sum'],
        'total_handled': manager_hist['total_handled'],
        'manager_conversion_rate': manager_hist['manager_conversion_rate'],
        'manager_avg_contract_amount': manager_hist['manager_avg_contract_amount'],
        'manager_contracts_count': manager_hist['manager_contracts_count'],
        'hour': date_obj.hour,
        'day_of_week': date_obj.dayofweek,
        'is_weekend': 1 if date_obj.dayofweek >= 5 else 0,
        'days_since_start': (date_obj - pd.Timestamp('2024-01-01')).days,
    }

    # Кодирование
    features_df = pd.DataFrame([features])
    encoded_features = {}

    for col in categorical_cols:
        if col in features_df.columns:
            val = features_df[col].iloc[0]
            if val not in label_encoders[col].classes_:
                val = 'unknown'
                if 'unknown' not in label_encoders[col].classes_:
                    label_encoders[col].classes_ = np.append(label_encoders[col].classes_, 'unknown')
            encoded_col = col + '_encoded'
            encoded_features[encoded_col] = label_encoders[col].transform([val])[0]

    for col in features_df.columns:
        if col not in categorical_cols:
            encoded_features[col] = features_df[col].iloc[0]

    encoded_df = pd.DataFrame([encoded_features])

    missing_features = set(selected_features) - set(encoded_df.columns)
    for feat in missing_features:
        encoded_df[feat] = 0

    features_selected = encoded_df[selected_features]

    # Предсказание
    prob = model.predict_proba(features_selected)[0, 1]
    pred_class = 1 if prob >= BUSINESS_THRESHOLD else 0

    return prob, pred_class, features, features_selected

