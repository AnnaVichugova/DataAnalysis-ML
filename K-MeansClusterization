############################ ячейка 1 - импорт модулей #######################
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import warnings
from datetime import datetime
from google.colab import files

# Scikit-learn для кластеризации и предобработки
