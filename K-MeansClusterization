})

# Словарь для перевода признаков
feature_names_ru = {
    'customer_type': 'Тип клиента',
    'customer_status': 'Статус клиента',
    'manager_specialization': 'Специализация менеджера',
    'total_applications': 'Всего заявок клиента',
    'successful_applications': 'Успешных заявок клиента',
    'conversion_rate': 'Конверсия клиента (%)'
}

############################ ячейка 3 - подготовка к кластеризации #######################
# ============================================================
# ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
# ============================================================
# Функция для предобработки дат
def preprocess_dates(df, date_columns):
    for col in date_columns:
        if col in df.columns:
            df[col] = pd.to_datetime(df[col], errors='coerce')
    return df

# Предобработка дат
df_applications = preprocess_dates(df_applications, ['Дата поступления', 'Дата закрытия'])
df_documents = preprocess_dates(df_documents, ['Дата создания'])
if 'Дата' in df_payments.columns:
    df_payments['Дата'] = pd.to_datetime(df_payments['Дата'], format='%d.%m.%Y', errors='coerce')

print("=== Данные загружены ===\n")

# ============================================================
# СОЗДАНИЕ МАППИНГА customer_id -> ИНН (customer_inn)
# ============================================================
print("=== СОЗДАНИЕ СВЯЗЕЙ МЕЖДУ ТАБЛИЦАМИ ===")

# Убедимся, что ИНН - строкового типа для корректного сопоставления
df_customers['customer_inn'] = df_customers['customer_inn'].astype(str)
df_documents['ИНН контрагента'] = df_documents['ИНН контрагента'].astype(str)
df_payments['ИНН плательщика'] = df_payments['ИНН плательщика'].astype(str)

# Создаем маппинг: customer_id -> ИНН (customer_inn)
customer_id_to_inn = df_customers.set_index('customer_id')['customer_inn'].to_dict()
inn_to_customer_id = {v: k for k, v in customer_id_to_inn.items()}

print(f"✓ Создан маппинг для {len(customer_id_to_inn)} клиентов")

# ============================================================
# 1. АГРЕГАЦИЯ ПРИЗНАКОВ ДЛЯ КЛАСТЕРИЗАЦИИ КЛИЕНТОВ
# ============================================================

# ---- Признаки из заявок (группируем по ИНН через маппинг) ----
print("\n--- Обработка заявок ---")

# Добавляем ИНН клиента в заявки
df_applications_with_inn = df_applications.copy()
df_applications_with_inn['ИНН_клиента'] = df_applications_with_inn['Клиент'].map(customer_id_to_inn)

# Проверяем, сколько заявок успешно сопоставилось
mapped_count = df_applications_with_inn['ИНН_клиента'].notna().sum()
print(f"  Заявок с сопоставленным ИНН: {mapped_count} из {len(df_applications_with_inn)}")

# Если не сопоставилось, возможно 'Клиент' - это название компании
if mapped_count == 0:
    print("  Внимание: не удалось сопоставить заявки по customer_id.")
    print("  Пробуем сопоставить по названию клиента...")
    
    # Создаем маппинг по названию клиента
    name_to_inn = df_customers.set_index('customer_name')['customer_inn'].to_dict()
    df_applications_with_inn['ИНН_клиента'] = df_applications_with_inn['Клиент'].map(name_to_inn)
    mapped_count = df_applications_with_inn['ИНН_клиента'].notna().sum()
    print(f"  Заявок с сопоставленным ИНН по названию: {mapped_count} из {len(df_applications_with_inn)}")

# Группируем по ИНН
applications_features = df_applications_with_inn.groupby('ИНН_клиента').agg({
    'Номер': 'count',
    'Статус': lambda x: (x == 'завершена').sum(),
}).rename(columns={'Номер': 'total_applications', 'Статус': 'successful_applications'})

applications_features['success_rate'] = (applications_features['successful_applications'] / 
                                          applications_features['total_applications']).fillna(0)

print(f"✓ Создано {len(applications_features)} записей в applications_features")

