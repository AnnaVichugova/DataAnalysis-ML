        'Каток': 'Дорожная', 'Асфальтоукладчик': 'Дорожная', 'Дорожная фреза': 'Дорожная',
        'Разметочная машина': 'Дорожная',
        
        # Строительная
        'Бетономешалка': 'Строительная', 'Экскаватор': 'Строительная', 'Бульдозер': 'Строительная',
        'Сваебой': 'Строительная', 'Бур': 'Строительная', 'Вибропогружатель': 'Строительная',
        
        # Грузоподъемная
        'Кран': 'Грузоподъемная', 'Погрузчик': 'Грузоподъемная', 'Автолифт': 'Грузоподъемная',
        'Автовышка': 'Грузоподъемная', 'Манипулятор': 'Грузоподъемная', 'Подъемная площадка': 'Грузоподъемная',
        'Стационарный кран': 'Грузоподъемная', 'Автомобильный кран': 'Грузоподъемная',
        
        # Транспортная
        'Самосвал': 'Транспортная', 'Трал': 'Транспортная', 'Автопоезд': 'Транспортная',
        'Бункеровоз': 'Транспортная', 'Бортовой грузовик': 'Транспортная', 'Цистерна': 'Транспортная',
        'Фура': 'Транспортная', 'Низкорамник': 'Транспортная',
        
        # Коммунальная
        'Разбрасыватель реагентов': 'Коммунальная', 'Ассенизатор': 'Коммунальная',
        'Снегоуборщик': 'Коммунальная', 'Моечная техника': 'Коммунальная',
        'Поливальная машина': 'Коммунальная', 'Мусоровоз': 'Коммунальная',
        
        # Сельскохозяйственная
        'Трактор': 'Сельскохозяйственная', 'Опрыскиватель': 'Сельскохозяйственная',
        'Комбайн': 'Сельскохозяйственная', 'Кормоуборщик': 'Сельскохозяйственная',
        'Жатка': 'Сельскохозяйственная', 'Сеялка': 'Сельскохозяйственная',
        
        # Лесозаготовительная
        'Харвестер': 'Лесозаготовительная', 'Форвардер': 'Лесозаготовительная',
        'Трелёвочный трактор': 'Лесозаготовительная', 'Лесовоз': 'Лесозаготовительная',
        'Измельчитель': 'Лесозаготовительная', 'Скиддер': 'Лесозаготовительная',
        'Валочно-пакетирующая техника': 'Лесозаготовительная',
        
        # Горнодобывающая
        'Шахтная машина': 'Горнодобывающая', 'Буровая мачта': 'Горнодобывающая',
        'Карьерная грузовая техника': 'Горнодобывающая', 'Забойная машина': 'Горнодобывающая',
        'Копровая установка': 'Горнодобывающая', 'Дробильная машина': 'Горнодобывающая',
    }
    for equip, category in equipment_map.items():
        if equip.lower() in text.lower():
            return category
    return 'other'

df_applications_with_inn['equipment_type'] = df_applications_with_inn['Содержание заявки'].apply(extract_equipment_type)

# Создаем crosstab для техники
equipment_preferences = pd.crosstab(df_applications_with_inn['ИНН_клиента'], df_applications_with_inn['equipment_type'])
print(f"✓ Создано equipment_preferences: {equipment_preferences.shape}")

# Убедимся, что все нужные колонки присутствуют
expected_equipment = ['Дорожная', 'Строительная', 'Коммунальная', 'other']
for eq in expected_equipment:
    if eq not in equipment_preferences.columns:
        equipment_preferences[eq] = 0
        print(f"  Добавлена недостающая колонка: {eq}")

# Переименуем колонки для удобства
equipment_preferences = equipment_preferences.rename(columns={
    'Дорожная': 'road',
    'Строительная': 'construction',
    'Коммунальная': 'municipal',
    'other': 'other'
})

# ---- Признаки из документов (группируем по ИНН контрагента) ----
print("\n--- Обработка документов ---")

documents_features = pd.DataFrame()
if 'Тип контрагента' in df_documents.columns and 'Сумма' in df_documents.columns:
    # Фильтруем только клиентов
    client_docs = df_documents[df_documents['Тип контрагента'] == 'Клиент'].copy()
    print(f"  Найдено документов для клиентов: {len(client_docs)}")
    
    if not client_docs.empty:
        documents_features = client_docs.groupby('ИНН контрагента').agg({
            'Сумма': ['sum', 'mean', 'count'],
            'Статус': lambda x: (x == 'подписан').sum() if 'Статус' in client_docs.columns else 0
        }).fillna(0)
        documents_features.columns = ['total_sum', 'avg_sum', 'doc_count', 'signed_docs']
        print(f"✓ Создано {len(documents_features)} записей в documents_features")
    else:
        print("⚠ Нет документов с Тип контрагента = 'Клиент'")
else:
    print("⚠ В данных о документах нет нужных колонок")

# ---- Платежная активность (группируем по ИНН плательщика) ----
print("\n--- Обработка платежей ---")

payments_features = pd.DataFrame()
if 'Тип' in df_payments.columns and 'ИНН плательщика' in df_payments.columns and 'Сумма' in df_payments.columns:
    incoming_payments = df_payments[df_payments['Тип'] == 'Входящий'].copy()
    print(f"  Найдено входящих платежей: {len(incoming_payments)}")
    
    if not incoming_payments.empty:
        payments_features = incoming_payments.groupby('ИНН плательщика').agg({
            'Сумма': ['sum', 'mean', 'count']
        }).fillna(0)
        payments_features.columns = ['payment_sum', 'payment_avg', 'payment_count']
        print(f"✓ Создано {len(payments_features)} записей в payments_features")
    else:
        print("⚠ Нет входящих платежей")
else:
    print("⚠ В данных о платежах нет нужных колонок")

# ---- Объединение всех признаков по ИНН ----
print("\n--- Объединение признаков ---")

# Создаем DataFrame с клиентами, индексированный по ИНН (customer_inn)
df_customers_by_inn = df_customers.copy()
df_customers_by_inn.set_index('customer_inn', inplace=True)
print(f"  Клиентов в df_customers: {len(df_customers_by_inn)}")

# Добавляем признаки из заявок
df_customers_enhanced = df_customers_by_inn.join(applications_features, how='left').fillna(0)
print(f"  После добавления заявок: {len(df_customers_enhanced)} клиентов")

# Добавляем признаки по типам техники
df_customers_enhanced = df_customers_enhanced.join(equipment_preferences, how='left').fillna(0)
print(f"  После добавления техники: {len(df_customers_enhanced)} клиентов")

# Добавляем признаки из документов
if not documents_features.empty:
    df_customers_enhanced = df_customers_enhanced.join(documents_features, how='left').fillna(0)
    print(f"  После добавления документов: {len(df_customers_enhanced)} клиентов")
else:
    for col in ['total_sum', 'avg_sum', 'doc_count', 'signed_docs']:
        df_customers_enhanced[col] = 0
    print("  ⚠ Признаки из документов не добавлены")

# Добавляем признаки из платежей
if not payments_features.empty:
    df_customers_enhanced = df_customers_enhanced.join(payments_features, how='left').fillna(0)
    print(f"  После добавления платежей: {len(df_customers_enhanced)} клиентов")
else:
    for col in ['payment_sum', 'payment_avg', 'payment_count']:
        df_customers_enhanced[col] = 0
    print("  ⚠ Признаки из платежей не добавлены")

# ---- Добавляем информацию о менеджере ----
print("\n--- Информация о менеджерах ---")

if 'Менеджер' in df_applications.columns and 'manager_id' in df_managers.columns:
    manager_mapping = df_managers.set_index('manager_id')['manager_specialization'].to_dict()
    df_customers_enhanced['manager_specialization'] = 'unknown'
    
    # Используем заявки с уже добавленным ИНН
    for inn in df_customers_enhanced.index:
        customer_apps = df_applications_with_inn[df_applications_with_inn['ИНН_клиента'] == inn]
        if len(customer_apps) > 0:
            manager_id = customer_apps['Менеджер'].mode().iloc[0] if len(customer_apps['Менеджер'].mode()) > 0 else None
            if manager_id and manager_id in manager_mapping:
                df_customers_enhanced.loc[inn, 'manager_specialization'] = manager_mapping[manager_id]
    
    managers_assigned = (df_customers_enhanced['manager_specialization'] != 'unknown').sum()
    print(f"✓ Добавлена специализация менеджера для {managers_assigned} клиентов")
else:
    df_customers_enhanced['manager_specialization'] = 'unknown'
    print("⚠ Нет данных о менеджерах")

# ---- Проверка результатов ----
print("\n" + "="*80)
print("ПРОВЕРКА РЕЗУЛЬТАТОВ ОБЪЕДИНЕНИЯ")
print("="*80)

nonzero_docs = df_customers_enhanced[df_customers_enhanced['total_sum'] > 0]
nonzero_payments = df_customers_enhanced[df_customers_enhanced['payment_sum'] > 0]

print(f"Клиентов с документами: {len(nonzero_docs)}")
print(f"Клиентов с платежами: {len(nonzero_payments)}")
print(f"Общая сумма документов по всем клиентам: {df_customers_enhanced['total_sum'].sum():,.2f} руб.")
print(f"Общая сумма платежей по всем клиентам: {df_customers_enhanced['payment_sum'].sum():,.2f} руб.")

if len(nonzero_docs) > 0:
    print("\nПримеры клиентов с документами:")
    print(nonzero_docs[['customer_name', 'total_sum', 'doc_count', 'signed_docs', 'payment_sum']].head(10))

# ============================================================
# ПОДГОТОВКА К КЛАСТЕРИЗАЦИИ
# ============================================================

# Словарь для перевода признаков на русский
feature_names_ru_cluster = {
    'total_applications': 'Всего заявок',
    'successful_applications': 'Успешных заявок',
    'success_rate': 'Успешность заявок',
    'total_sum': 'Общая сумма документов',
    'avg_sum': 'Средняя сумма документа',
    'doc_count': 'Количество документов',
    'signed_docs': 'Подписанных документов',
    'payment_sum': 'Общая сумма платежей',
    'payment_avg': 'Средний платеж',
    'payment_count': 'Количество платежей',
    'road': 'Дорожная техника',
    'construction': 'Строительная техника',
    'municipal': 'Коммунальная техника',
    'other': 'Другая техника',
    'manager_specialization': 'Специализация менеджера'
}

# Кодирование категориальных признаков
categorical_cols = ['customer_type', 'customer_status', 'manager_specialization']
label_encoders_cluster = {}

for col in categorical_cols:
    if col in df_customers_enhanced.columns:
        le = LabelEncoder()
        df_customers_enhanced[col + '_encoded'] = le.fit_transform(df_customers_enhanced[col].astype(str))
        label_encoders_cluster[col] = le

# Выбираем числовые признаки для кластеризации
numeric_features = ['total_applications', 'success_rate', 'total_sum', 'avg_sum', 
                    'doc_count', 'signed_docs', 'payment_sum', 'payment_avg', 'payment_count']

# Добавляем признаки по типам техники (теперь они точно есть)
equipment_cols = ['road', 'construction', 'municipal', 'other']
for col in equipment_cols:
    if col not in df_customers_enhanced.columns:
        df_customers_enhanced[col] = 0
        print(f"  Добавлена недостающая колонка: {col}")
    numeric_features.append(col)

# Убираем NaN и бесконечности
for col in numeric_features:
    if col in df_customers_enhanced.columns:
        df_customers_enhanced[col] = df_customers_enhanced[col].replace([np.inf, -np.inf], 0).fillna(0)

X_cluster = df_customers_enhanced[numeric_features]

print("\n=== Признаки для кластеризации ===")
print("─" * 50)
for col in X_cluster.columns:
    ru_name = feature_names_ru_cluster.get(col, col)
    print(f"  • {ru_name}")
print(f"\nРазмерность: {X_cluster.shape[0]} клиентов, {X_cluster.shape[1]} признаков")

############################ ячейка 4 - кластеризация #######################

# Нормализация
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X_cluster)

# Определение оптимального числа кластеров
inertias = []
silhouette_scores = []
K_range = range(2, 8)

for k in K_range:
    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)
    kmeans.fit(X_scaled)
    inertias.append(kmeans.inertia_)
    silhouette_scores.append(silhouette_score(X_scaled, kmeans.labels_))

# Визуализация
fig, axes = plt.subplots(1, 2, figsize=(12, 4))

axes[0].plot(K_range, inertias, 'bo-', linewidth=2, markersize=8)
axes[0].set_xlabel('Число кластеров', fontsize=11)
axes[0].set_ylabel('Инерция', fontsize=11)
axes[0].set_title('Метод локтя для выбора числа кластеров', fontsize=12)
axes[0].grid(True, alpha=0.3)

axes[1].plot(K_range, silhouette_scores, 'ro-', linewidth=2, markersize=8)
axes[1].set_xlabel('Число кластеров', fontsize=11)
axes[1].set_ylabel('Silhouette Score', fontsize=11)
axes[1].set_title('Оценка силуэта', fontsize=12)
axes[1].grid(True, alpha=0.3)

plt.tight_layout()
plt.show()

# Выбираем оптимальное число кластеров
optimal_k = 4
kmeans = KMeans(n_clusters=optimal_k, random_state=42, n_init=10)
clusters = kmeans.fit_predict(X_scaled)

df_customers_enhanced['Cluster'] = clusters

# 3. АНАЛИЗ КЛАСТЕРОВ

# Статистика по кластерам (с русскими названиями)
cluster_stats = df_customers_enhanced.groupby('Cluster')[numeric_features].mean()
cluster_stats_ru = cluster_stats.rename(columns=feature_names_ru_cluster)
cluster_counts = df_customers_enhanced['Cluster'].value_counts().sort_index()

print("\n" + "="*80)
print("📊 РАСПРЕДЕЛЕНИЕ ПО КЛАСТЕРАМ")
print("="*80)
for cluster_id in range(optimal_k):
    count = cluster_counts[cluster_id]
    percent = count / cluster_counts.sum() * 100
    print(f"  Кластер {cluster_id}: {count} клиентов ({percent:.1f}%)")

print("\n" + "="*80)
print("📊 ХАРАКТЕРИСТИКИ КЛАСТЕРОВ (средние значения)")
print("="*80)
print(cluster_stats_ru.round(2).to_string())

# Визуализация кластеров (2D проекция)
from sklearn.decomposition import PCA

pca = PCA(n_components=2)
X_pca = pca.fit_transform(X_scaled)

plt.figure(figsize=(10, 6))
scatter = plt.scatter(X_pca[:, 0], X_pca[:, 1], c=clusters, cmap='viridis', s=50, alpha=0.7)
plt.colorbar(scatter, label='Кластер')
plt.xlabel('Первая главная компонента', fontsize=11)
plt.ylabel('Вторая главная компонента', fontsize=11)
plt.title('Визуализация кластеров клиентов (PCA)', fontsize=13, fontweight='bold')
plt.grid(True, alpha=0.3)
plt.show()

# 4. ГЕНЕРАЦИЯ ГИПОТЕЗЫ

print("\n" + "="*80)
print("🎯 ГЕНЕРАЦИЯ БИЗНЕС-ГИПОТЕЗЫ НА ОСНОВЕ КЛАСТЕРИЗАЦИИ")
print("="*80)

# Анализ профилей кластеров
cluster_profiles = {}

for cluster_id in range(optimal_k):
    cluster_data = df_customers_enhanced[df_customers_enhanced['Cluster'] == cluster_id]
    
    profile = {
        'size': len(cluster_data),
        'avg_applications': cluster_data['total_applications'].mean(),
        'success_rate': cluster_data['success_rate'].mean(),
        'avg_doc_sum': cluster_data['avg_sum'].mean(),
        'total_doc_sum': cluster_data['total_sum'].mean(),
        'doc_count': cluster_data['doc_count'].mean(),
        'signed_docs': cluster_data['signed_docs'].mean(),
    }
    
    for eq in equipment_cols:
        profile[f'avg_{eq}'] = cluster_data[eq].mean()
    
    if equipment_cols:
        eq_means = {eq: cluster_data[eq].mean() for eq in equipment_cols}
        main_eq = max(eq_means, key=eq_means.get) if eq_means else 'unknown'
        profile['main_equipment'] = feature_names_ru_cluster.get(main_eq, main_eq)
    else:
        profile['main_equipment'] = 'unknown'
    
    cluster_profiles[cluster_id] = profile

