# Шаг 1: Определяем целевую переменную (конверсию)
def determine_conversion(status):
    if status == 'завершена':
        return 1
    elif status in ['отменена', 'заморожена']:
        return 0
    else:
        return np.nan

df_applications['is_converted'] = df_applications['Статус'].apply(determine_conversion)

