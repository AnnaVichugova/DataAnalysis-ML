    print(f"  → Насколько объекты похожи на объекты внутри своего кластера")
    print(f"    (диапазон от -1 до 1, чем выше, тем лучше)")
    
    # Индекс Дэвиса-Болдина (чем ниже, тем лучше)
    db_score = davies_bouldin_score(X_sample, y_sample)
