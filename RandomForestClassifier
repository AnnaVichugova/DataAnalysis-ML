    print(f"  → Средняя 'похожесть' между кластером и его соседом")
    print(f"    (чем меньше, тем лучше разделение кластеров)")
    
    # Adjusted Rand Index (сравнение с истинными метками)
    ari_score = adjusted_rand_score(y_sample, y_pred[X_sample.index])
    print(f"\nAdjusted Rand Index (ARI): {ari_score:.4f}")
    print(f"  → Сравнение полученного разбиения с истинными метками")
    print(f"    (1 = идеальное совпадение, 0 = случайное)")
    
except Exception as e:
    print(f"\n  Примечание: метрики кластеризации не рассчитаны")
    print(f"  ({str(e)[:100]})")

