# Формируем признаки для предсказания
def prepare_features_for_prediction(app, customer, manager):
    features = {}
    
    features['Источник'] = app['Источник']
    features['Тип_клиента'] = customer['customer_type'] if customer is not None else 'unknown'
    features['Статус_клиента'] = customer['customer_status'] if customer is not None else 'unknown'
    
    if customer is not None:
        features['Регион'] = extract_region(customer['customer_address'])
    else:
        features['Регион'] = 'unknown'
    
    features['Специализация_менеджера'] = manager['manager_specialization'] if manager is not None else 'unknown'
    features['Менеджер'] = manager['manager_name'] if manager is not None else 'unknown'
    
    features['Запрошенное_количество'] = extract_quantity_improved(app['Содержание заявки'])
    features['Длина_заявки'] = len(app['Содержание заявки'])
    features['Срочность'] = 1 if 'сроч' in app['Содержание заявки'].lower() else 0
    
    date = pd.to_datetime(app['Дата поступления'], errors='coerce')
    features['День_недели'] = date.dayofweek
    features['Месяц'] = date.month
    
    return features

