X['Тип_клиента'] = merged_df['customer_type'].fillna('unknown')
X['Статус_клиента'] = merged_df['customer_status'].fillna('unknown')
X['Специализация_менеджера'] = merged_df['manager_specialization'].fillna('unknown')
X['Менеджер'] = merged_df['manager_name'].fillna('unknown')

# Извлекаем регион из адреса
def extract_region(address):
    if pd.isna(address):
        return 'unknown'
    parts = str(address).split(',')
    return parts[0].strip() if len(parts) >= 1 else 'unknown'

X['Регион'] = merged_df['customer_address'].apply(extract_region)

# Извлекаем количество техники из текста заявки
def extract_quantity(text):
    if pd.isna(text):
        return 0
    match = re.search(r'в количестве (\d+)', str(text))
    return int(match.group(1)) if match else 0

